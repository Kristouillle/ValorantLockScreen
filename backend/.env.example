# Backend host/port
HOST=127.0.0.1
PORT=8787

# Feed behavior
MATCH_CACHE_TTL_MS=30000
UPSTREAM_POLL_INTERVAL_MS=30000
LOG_LEVEL=info
LOG_MATCH_PAYLOADS=false

# Riot schedule source
RIOT_SCHEDULE_URL=https://valorantesports.com/en-US/schedule

# ActivityKit / APNs push configuration
# Use sandbox for debug/dev signed builds installed from Xcode.
APNS_ENVIRONMENT=sandbox
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
# Paste the .p8 key on one line and keep \n escapes intact.
APNS_PRIVATE_KEY=
# Optional. Defaults to ${APNS_BUNDLE_ID}.push-type.liveactivity
APNS_TOPIC=
