# Backend host/port
HOST=127.0.0.1
PORT=8787

# Feed behavior
MATCH_CACHE_TTL_MS=30000
UPSTREAM_POLL_INTERVAL_MS=30000
SIMULATOR_ENABLED=true
# Optional: set both in staging/production to require browser auth on /simulate
SIMULATOR_USERNAME=
SIMULATOR_PASSWORD=
MAX_REQUEST_BODY_BYTES=16384
REGISTRATION_TTL_MS=86400000
MATCH_REQUEST_LIMIT=120
MATCH_REQUEST_WINDOW_MS=60000
REGISTRATION_REQUEST_LIMIT=30
REGISTRATION_REQUEST_WINDOW_MS=60000
LOG_LEVEL=info
LOG_MATCH_PAYLOADS=false

# Riot schedule source
RIOT_SCHEDULE_URL=https://valorantesports.com/en-US/schedule

# ActivityKit / APNs push configuration
# Use sandbox for debug/dev signed builds installed from Xcode.
APNS_ENVIRONMENT=sandbox
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
# Paste the .p8 key on one line and keep \n escapes intact.
APNS_PRIVATE_KEY=
# Optional. Defaults to ${APNS_BUNDLE_ID}.push-type.liveactivity
APNS_TOPIC=
